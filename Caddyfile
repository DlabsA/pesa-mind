# Production domain - Let's Encrypt (requires proper DNS)
# Only uncomment when DNS is properly configured
# api.dlabs.cc {
#     reverse_proxy app:8080
# }

# Development/Staging - Self-signed certificates

# HTTP on both :80 and :8080
http://:80 {
	reverse_proxy app:8080
}

http://:8080 {
	reverse_proxy app:8080
}

# HTTPS on both :443 and :8443
https://:443 {
	tls internal
	reverse_proxy app:8080
}

https://:8443 {
	tls internal
	reverse_proxy app:8080
}

# Wildcard for any other hostname with self-signed cert
* {
	tls internal
	reverse_proxy app:8080
}
